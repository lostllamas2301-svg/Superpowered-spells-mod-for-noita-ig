        gravity_y="50" 
        air_friction="-5.0" 
		mass="0.05"
		>
    </VelocityComponent>
	</Base>

  <ProjectileComponent 
    _enabled="1" 
    lob_min="0.8"
    lob_max="1.0"
    speed_min="70"
    speed_max="100"
    direction_random_rad="0.0"
